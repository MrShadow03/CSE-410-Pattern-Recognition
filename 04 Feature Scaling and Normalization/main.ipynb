    "scaler = MinMaxScaler()\n",
    "df[['Age', 'Fare']] = scaler.fit_transform(df[['Age', 'Fare']])\n",
    "\n",
    "df[['Age', 'Fare']].head()\n",
    "print(df['Age'].mean())"
